{
  "name": "luohammer-pixel-game",
  "version": "1.0.0",
  "description": "真还传·人生模拟 — 罗远人生选择模拟器",
  "main": "electron/main.cjs",
  "type": "module",
  "author": "TRAE AI 开发者大赛",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently -k \"npm:dev\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "electron": "electron .",
    "build": "vite build",
    "build:electron": "npm run build && electron-builder",
    "build:electron:dir": "npm run build && electron-builder --dir",
    "preview": "vite preview",
    "deploy": "node scripts/deploy-oss.mjs",
    "lint": "eslint src --ext .js --max-warnings 0",
    "lint:fix": "eslint src --ext .js --fix",
    "format": "prettier --write \"src/**/*.{js,css}\" \"index.html\""
  },
  "build": {
    "appId": "com.trae.luohammer",
    "productName": "真还传·人生模拟",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon-512.png",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "真还传·人生模拟",
      "installerIcon": "public/icon-512.png",
      "uninstallerIcon": "public/icon-512.png",
      "installerHeaderIcon": "public/icon-512.png",
      "deleteAppDataOnUninstall": false
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    }
  },
  "dependencies": {
    "phaser": "^3.80.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@vitest/coverage-v8": "^4.1.9",
    "acorn": "^8.16.0",
    "ali-oss": "^6.23.0",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.3.0",
    "sharp": "^0.35.1",
    "terser": "^5.48.0",
    "vite": "^5.4.0",
    "vitest": "^4.1.9",
    "wait-on": "^9.0.10"
  }
}
